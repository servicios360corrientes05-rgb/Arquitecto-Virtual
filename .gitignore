# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# logs PM2
/logs/
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Google OAuth credentials (NUNCA commitear)
service-account.json
credentials.json
token.json

# Perfiles de Chrome (sesión DGC - datos sensibles)
/data/chrome_profile_provincia*/
/data/chrome_profile*/

# Archivos generados / caché de scraping
/data/scraper_cache.json
/data/ultimo_scrapeo.json
/data/mensura_extracted_data.json
/data/error_dump_*.html
# /data/regulations/ (Habilitado para que se suba a Railway)
!/data/regulations/
!/data/regulations/*.json

# PDFs generados e informes (no van al repo)
/public/informes/
/cola_de_proceso/

# Archivos de debug
/assets/debug/

# Backups locales
/backups/

# Videos grandes (usar CDN o storage externo en producción)
*.mp4
*.webp
*.webm
*.mov

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
