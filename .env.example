# ===========================================
# ARQUITECTO VIRTUAL - Variables de Entorno
# ===========================================
# Copia este archivo como .env.local y completa los valores

# OpenAI (existente en el proyecto)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Google APIs (Maps, Sheets, etc.)
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx

# Google Service Account (opcional, para backend)
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-cuenta@proyecto.iam.gserviceaccount.com

# Catastro Provincial DGC Corrientes
DGC_CATASTRO_USER=tu_usuario
DGC_CATASTRO_PASS=tu_contraseña
